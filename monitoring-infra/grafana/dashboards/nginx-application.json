{
  "title": "Application / Nginx",
  "uid": "nginx-application",
  "description": "Nginx connection metrics via nginx-prometheus-exporter. HTTP status breakdown requires Loki (Phase 5).",
  "tags": ["nginx", "application", "infrastructure"],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "title": "System Overview",
      "url": "/d/system-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Active Connections",
      "description": "Current number of active client connections to Nginx",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red",    "value": 400 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_active",
          "legendFormat": "Active",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "description": "HTTP requests handled per second (averaged over last 1 minute)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 1000 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "Req/s",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests (lifetime)",
      "description": "Cumulative HTTP requests served since Nginx started",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": null } ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_http_requests_total",
          "legendFormat": "Total Requests",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Connection Drop Rate",
      "description": "Connections accepted but not handled (accepted - handled). Should be 0.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_accepted - nginx_connections_handled",
          "legendFormat": "Dropped",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Active Connections Over Time",
      "description": "Live view of active connections. Sudden spikes indicate traffic bursts; sustained highs may indicate slow clients.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "line", "show": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red",    "value": 400 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_active",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "Number of HTTP requests served per second. The steady-state baseline and spikes are key.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "Requests / sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "rate(nginx_http_requests_total[5m])",
          "legendFormat": "Requests / sec (5m avg)",
          "refId": "B"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Connection States Breakdown",
      "description": "Reading = headers being read. Writing = response being sent. Waiting = keep-alive idle. High 'waiting' is normal for keep-alive workloads.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_reading",
          "legendFormat": "Reading",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_writing",
          "legendFormat": "Writing",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "nginx_connections_waiting",
          "legendFormat": "Waiting (keep-alive)",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Connections Accepted vs Handled",
      "description": "Accepted and handled should be equal. A gap means Nginx is dropping connections (worker_connections limit reached).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "rate(nginx_connections_accepted[1m])",
          "legendFormat": "Accepted / sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "expr": "rate(nginx_connections_handled[1m])",
          "legendFormat": "Handled / sec",
          "refId": "B"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Request Rate by Status Code",
      "description": "Requests per second broken down by HTTP status code, parsed from Nginx access logs via Loki. 2xx = success, 4xx = client errors, 5xx = server errors.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^4.*" },
            "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^5.*" },
            "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^2.*" },
            "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum by (status) (rate({job=\"nginx\"} | pattern `<_> - <_> [<_>] \"<_>\" <status> <_>` [1m]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "4xx / 5xx Error Rate",
      "description": "Rate of client (4xx) and server (5xx) errors per second. Both should be as close to 0 as possible in a healthy system.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "none",
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "4xx Client Errors" },
            "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx Server Errors" },
            "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(rate({job=\"nginx\"} | pattern `<_> - <_> [<_>] \"<_>\" <status> <_>` | status >= `400` | status < `500` [1m]))",
          "legendFormat": "4xx Client Errors",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(rate({job=\"nginx\"} | pattern `<_> - <_> [<_>] \"<_>\" <status> <_>` | status >= `500` [1m]))",
          "legendFormat": "5xx Server Errors",
          "refId": "B"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Average Response Time (from logs)",
      "description": "Mean Nginx request time in milliseconds, derived from the rt= field in access logs. Correlate spikes here with CPU / memory panels in System Overview.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "line", "show": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 2 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "avg_over_time({job=\"nginx\"} | pattern `<_> rt=<request_time>` | unwrap request_time [1m])",
          "legendFormat": "Avg response time",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "quantile_over_time(0.95, {job=\"nginx\"} | pattern `<_> rt=<request_time>` | unwrap request_time [1m])",
          "legendFormat": "p95 response time",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "type": "logs",
      "title": "Nginx Access Logs (live stream)",
      "description": "Real-time Nginx access logs. Use the search bar to filter by path, IP, or status code. Click any line to expand its parsed labels.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "{job=\"nginx\"}",
          "refId": "A",
          "maxLines": 200
        }
      ]
    },

    {
      "id": 13,
      "type": "logs",
      "title": "Node.js App Logs (live stream)",
      "description": "Real-time logs from the Node.js target-app container. Errors are highlighted automatically. Use |= 'error' to filter.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 46 },
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "{job=\"app\"}",
          "refId": "A",
          "maxLines": 200
        }
      ]
    }

  ]
}
